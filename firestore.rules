rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // REGRA GERAL PARA COLEÇÕES DAS TURMAS E REGISTROS
    // Permite acesso se o nome da coleção for um dos permitidos.
    match /{collectionId}/{docId=**} {
      allow read, write: if request.auth != null &&
        (collectionId == 'turma a' || 
         collectionId == 'turma b' || 
         collectionId == 'turma c' ||
         collectionId == 'turma d' ||
         collectionId == 'turma c cg' ||
         collectionId == 'registrosDSS A' || 
         collectionId == 'registrosDSS B' ||
         collectionId == 'registrosDSS C' ||
         collectionId == 'registrosDSS D' ||
         collectionId == 'registrosDSS C CG');
    }

    // REGRA PARA LOG DE AUDITORIA
    // Permite criar e ler registros de auditoria para usuários autenticados.
    match /registros_auditoria/{logId} {
      allow read, write: if request.auth != null;
    }

    // REGRA PARA CONFIGURACOES (AUTOMACAO, ETC)
    // Permite controlar painel administrativo
    match /configuracoes/{docId} {
      allow read, write: if request.auth != null;
    }

    // REGRA DE SEGURANÇA PARA ADMINISTRADORES
    // Permite apenas ler a lista de admins, mas proíbe criar ou editar pelo app.
    match /administrators/{adminId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // REGRA PARA HISTÓRICO DSS
    // Permite leitura para consultar o histórico pelo painel. Escrita bloqueada (feita pelo Admin SDK).
    match /historico_dss/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}